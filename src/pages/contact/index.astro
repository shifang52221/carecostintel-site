---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact CareCost Intelligence | Corrections, Support, and Editorial Questions" description="Contact CareCost Intelligence for correction requests, methodology questions, technical issues, licensing inquiries, or editorial feedback about our senior care planning tools and guides.">
  <section class="section">
    <div class="container">
      <span class="pill">We welcome corrections</span>
      <h1>Contact CareCost Intelligence</h1>
      <p class="note">Updated: Mar 2026. Use this page for corrections, methodology questions, technical support, accessibility feedback, or licensing inquiries.</p>
      <div class="tag">Last updated: Mar 2026</div>
      <div class="editorial-meta">Reviewed by CareCost Intelligence Editorial Team</div>
      <div class="author-box">
        <div class="author-title">Response standards</div>
        <div class="author-meta">
          <div>
            <strong>CareCost Intelligence Editorial Team</strong>
            <p class="note">For editorial transparency, see our <a href="/editorial-policy/">Editorial Policy</a> and <a href="/updates/">Updates &amp; Corrections</a>.</p>
          </div>
        </div>
      </div>
      <div class="controls">
        <a class="btn" href="mailto:hello@carecostintel.com">Email hello@carecostintel.com</a>
        <a class="btn secondary" href="/updates/">View corrections log</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div class="card">
        <h2>What to contact us about</h2>
        <ul class="checklist">
          <li>Factual corrections or stale source links.</li>
          <li>Estimator behavior, broken states, or calculation issues.</li>
          <li>Methodology and planning-range questions.</li>
          <li>Accessibility concerns or usability feedback.</li>
        </ul>
      </div>
      <div class="card">
        <h2>What helps us respond faster</h2>
        <ul class="checklist">
          <li>The full page URL.</li>
          <li>The section heading or feature name.</li>
          <li>A short explanation of the issue.</li>
          <li>A source link if you are requesting a correction.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div class="card">
        <h2>Contact details</h2>
        <p><strong>Email:</strong> <a href="mailto:hello@carecostintel.com">hello@carecostintel.com</a></p>
        <p class="note">Please do not send personal health records, Social Security numbers, insurance numbers, or other sensitive medical information.</p>
      </div>
      <div class="card">
        <h2>Typical response times</h2>
        <ul class="checklist">
          <li>Corrections: within 2 business days when source evidence is included.</li>
          <li>Technical issues: 1 to 2 business days.</li>
          <li>Licensing and partnership inquiries: 3 to 5 business days.</li>
          <li>Accessibility issues: as quickly as possible after verification.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container card">
      <h2>How corrections are handled</h2>
      <div class="grid-3">
        <div class="feature">
          <strong>Step 1: Review</strong>
          <p class="note">We verify the page, section, and source you reference.</p>
        </div>
        <div class="feature">
          <strong>Step 2: Update</strong>
          <p class="note">If a material correction is needed, we update the page and timestamp.</p>
        </div>
        <div class="feature">
          <strong>Step 3: Log</strong>
          <p class="note">Material corrections are reflected in <a href="/updates/">Updates &amp; Corrections</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div class="card">
        <h2>Licensing and partnerships</h2>
        <ul class="checklist">
          <li>Content licensing inquiries.</li>
          <li>Data or research collaboration proposals.</li>
          <li>Editorial partnership requests.</li>
          <li>Accessibility and nonprofit partnership outreach.</li>
        </ul>
      </div>
      <div class="card">
        <h2>What we do not provide</h2>
        <ul class="checklist">
          <li>No provider recommendations or referrals.</li>
          <li>No clinical or care-placement advice.</li>
          <li>No personal insurance or Medicaid eligibility determinations.</li>
          <li>No private quote negotiation services.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
