---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | CareCost Intelligence" description="The page you requested is unavailable. Use links to our estimator, state guides, and care planning resources to quickly continue your senior care cost research." robots="noindex, nofollow">
  <section class="section">
    <div class="container">
      <h1>Page not found</h1>
      <p class="note">The page you are looking for may have moved or no longer exists.</p>
      <div class="cta-strip" style="margin-top: 14px;">
        <div>
          <div class="badge">Quick recovery</div>
          <strong>Start from a core planning tool.</strong>
        </div>
        <a class="btn secondary" href="/estimator/">Open estimator</a>
      </div>
      <div class="controls" style="margin-top: 16px;">
        <a class="btn secondary" href="/state-costs/">State guides</a>
        <a class="btn secondary" href="/care-types/">Care types</a>
        <a class="btn secondary" href="/guides/">Guides</a>
        <a class="btn" href="/">Back to home</a>
      </div>
    </div>
  </section>
</BaseLayout>
