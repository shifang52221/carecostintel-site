---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Updates & Corrections | Change Log for CareCost Intelligence" description="Track major updates, methodology notes, and correction entries across the CareCost Intelligence site so readers can reference the latest planning guidance.">
  <section class="section">
    <div class="container">
      <span class="pill">Change log</span>
      <h1>Updates &amp; Corrections</h1>
      <p class="note">Updated: Mar 2026. This page records meaningful content updates, methodology notes, and corrections made across the site.</p>
      <div class="tag">Last updated: Mar 2026</div>
      <div class="editorial-meta">Maintained by CareCost Intelligence Editorial Team</div>
      <div class="controls">
        <a class="btn" href="/contact/">Report an issue</a>
        <a class="btn secondary" href="/methodology/">View methodology</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div class="card">
        <h2>How we use this page</h2>
        <ul class="checklist">
          <li>Major page updates are summarized here.</li>
          <li>Material methodology changes are logged here.</li>
          <li>Verified corrections are reflected here after publication.</li>
          <li>Minor copy edits may not receive a separate entry.</li>
        </ul>
      </div>
      <div class="card">
        <h2>When to contact us</h2>
        <ul class="checklist">
          <li>If you see a stale or broken official source.</li>
          <li>If a page misstates a program, policy, or quote-validation step.</li>
          <li>If the estimator behaves unexpectedly.</li>
          <li>If a page needs accessibility improvements.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container card">
      <h2>Recent updates</h2>
      <div class="grid-3">
        <div class="feature">
          <strong>Mar 2026</strong>
          <p class="note">Expanded trust and methodology documentation across the site and added a dedicated methodology page.</p>
        </div>
        <div class="feature">
          <strong>Feb 2026</strong>
          <p class="note">Expanded state planning guides and improved quote-validation workflows.</p>
        </div>
        <div class="feature">
          <strong>Jan 2026</strong>
          <p class="note">Refreshed annual planning guidance and estimator language for 2026 conditions.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div class="card">
        <h2>Methodology notes</h2>
        <ul class="checklist">
          <li>Mar 2026: clarified how production indexing and transparency pages are handled.</li>
          <li>Feb 2026: no material formula changes logged.</li>
          <li>Jan 2026: updated annual planning-language assumptions.</li>
        </ul>
      </div>
      <div class="card">
        <h2>Corrections log</h2>
        <ul class="checklist">
          <li>No material corrections logged for Mar 2026 at this time.</li>
          <li>Future verified corrections will be summarized here with affected page references.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
