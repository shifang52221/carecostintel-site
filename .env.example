SITE_URL=https://www.example.com
PUBLIC_ALLOW_INDEXING=false
PUBLIC_ADS_ENABLED=false

# Production checklist:
# 1. Set SITE_URL to the live canonical origin, including https://
# 2. Set PUBLIC_ALLOW_INDEXING=true only on the real production site
# 3. Keep PUBLIC_ALLOW_INDEXING=false for local, preview, and staging builds
